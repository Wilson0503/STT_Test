# Azure OpenAI Credentials (GPT-4o-transcribe)
AZURE_OPENAI_API_KEY=your-api-key-here

# Endpoint: 支援兩種格式
# === 格式 1: 只提供 base endpoint（推薦）===
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-transcribe
# AZURE_OPENAI_API_VERSION=2025-03-01-preview

# === 格式 2: 提供完整 URL（含部署名、api-version）===
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o-transcribe/audio/transcriptions?api-version=2025-03-01-preview

# 測試檔案路徑
GPT4O_MEDIA_FILE=C:\Users\iec150094\STT_Test\instella實戰攻略_27-85s.wav

# 轉錄語言（zh = 自動偵測中文，zh-TW = 繁體中文，en = 英文）
GPT4O_LANGUAGE=zh

# 可選：提示詞（幫助模型理解特定領域用語）
# GPT4O_TRANSCRIBE_PROMPT=This is an Inventec internal talk about Instella.
