# Azure Speech Realtime (Speech SDK)
# Either provide key + region
AZURE_SPEECH_KEY="your-speech-key"
#AZURE_SPEECH_REGION=eastus

# Or provide key + endpoint (works with custom domains)
#AZURE_SPEECH_ENDPOINT="https://eastus.api.cognitive.microsoft.com/"

# 支援的語言清單: 中文(簡体), 英文, 西班牙, 越南, 捷克
# 最多支援 10 種語言用於 Continuous 模式
AZURE_AUTO_LANGUAGES=en-US,zh-TW

# 語言偵測模式: AtStart(開頭判斷一次) / Continuous(持續判斷，較適合多語言混合)
#AZURE_LANGUAGE_ID_MODE=Continuous

# 可選: 即時 Phrase List（逗號分隔）
# 例: AZURE_PHRASE_LIST=Instella,Inventec,interesting
AZURE_PHRASE_LIST=
